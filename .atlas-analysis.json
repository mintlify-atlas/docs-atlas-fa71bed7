  "projectType": "infrastructure",
  "projectName": "TG WS Proxy",
  "projectDescription": "A local MTProto proxy for Telegram Desktop that routes traffic over WebSocket connections to bypass loading issues, with GUI tray apps for Windows, macOS, and Linux.",
